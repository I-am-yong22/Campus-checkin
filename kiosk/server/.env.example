# 共享数据库连接（与主后端使用同一个 MySQL；签到机所在网络需可访问该库）
# 本机自带 Docker MySQL 时：mysql://root:root123@127.0.0.1:3307/campus_checkin
DATABASE_URL="mysql://root:root123@127.0.0.1:3307/campus_checkin"

# 本地签到服务监听地址与端口（务必保持 127.0.0.1，防止被局域网/公网访问）
KIOSK_HOST=127.0.0.1
KIOSK_PORT=4100

# 人脸比对欧氏距离阈值（越小越严格；网络摄像头建议 0.38~0.45）
KIOSK_FACE_MATCH_THRESHOLD=0.45

# 现场人脸录入的管理口令（调用 /api/face/register 时需在请求头 x-admin-token 携带）
KIOSK_ADMIN_TOKEN="change-this-kiosk-token"

# 头像静态文件目录（默认指向主后端 uploads，与 /uploads 路径一致）
# UPLOADS_DIR="../../backend/uploads"
