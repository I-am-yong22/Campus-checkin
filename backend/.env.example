# 数据库连接（本机开发，Docker MySQL 映射到宿主机 3307 端口避免与本机已有 MySQL 冲突）
DATABASE_URL="mysql://root:root123@localhost:3307/campus_checkin"

# JWT
JWT_SECRET="change-this-secret-in-production"
JWT_EXPIRES_IN="7d"

# 服务端口
PORT=3000

# 人脸比对欧氏距离阈值（越小越严格，网络摄像头建议 0.38~0.45）
FACE_MATCH_THRESHOLD=0.42

# 跨域允许的前端地址
CORS_ORIGIN="http://localhost:5173,http://localhost:8080"
